{
  "manifest_version": 3,
  "name": "SHARE Lead Generator",
  "version": "3.2.0",
  "description": "Scrapes leads via Apify and dispatches them to the SHARE master sheet. Requires SHARE login; blocks deactivated users.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://console.apify.com/actors/IoSHqwTR9YGhzccez/input*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://email-monitoringbackend.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://console.apify.com/actors/IoSHqwTR9YGhzccez/input*"],
      "js": ["content.js"]
    }
  ]
}
